{
  "name": "management-service",
  "version": "0.0.1",
  "description": "NestJS Microservices Template",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "bun run prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun run dist/main.js",
    "lint": "bun run eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "bun run jest",
    "test:watch": "bun run jest --watch",
    "test:cov": "bun run jest --coverage",
    "test:e2e": "bun run jest --config ./test/jest-e2e.json",
    "typeorm": "bun ts-node ./node_modules/typeorm/cli",
    "migration:run": "bun run typeorm migration:run -- -d ./src/config/typeorm.config.ts",
    "migration:generate": "bun run typeorm -- -d ./src/config/typeorm.config.ts migration:generate ./src/migrations/$npm_config_name",
    "migration:create": "bun run typeorm -- migration:create ./src/migrations/$npm_config_name",
    "migration:revert": "bun run typeorm -- -d ./src/config/typeorm.config.ts migration:revert"
  },
  "dependencies": {
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/throttler": "^5.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "axios": "^1.7.3",
    "bcrypt": "^5.1.1",
    "cache-manager": "^5.3.0",
    "cache-manager-ioredis": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "nestjs-form-data": "^1.9.91",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "swagger-themes": "^1.4.3",
    "typeorm": "^0.3.20",
    "typeorm-transactional": "^0.5.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cache-manager": "^4.0.0",
    "@types/express": "^4.17.17",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.2",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "pactum": "^3.9.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
