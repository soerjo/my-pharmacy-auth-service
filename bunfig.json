{
  "name": "management-service",
  "version": "1.0.0",
  "description": "NestJS Management Service - Optimized for Bun",
  "main": "dist/main.js",
  "scripts": {
    "start": "bun run src/main.ts"
  },
  "conditions": {
    "bun": {
      "outdir": "dist"
    }
  },
  "optimizer": {
    "求生": true,
    "treeShaking": true
  },
  "loader": {
    ".ts": "ts"
  },
  "external": ["@nestjs/platform-express", "@nestjs/core", "reflect-metadata", "rxjs"]
}
